{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "address": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zipCode": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discount": { "type": "number" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "stock": { "type": "integer" },
        "imageURL": { "type": "string" },
        "ecoScore": { "type": "number" },
        "relatedProductIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "imageURL": { "type": "string" }
      },
      "required": ["name"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" },
              "imageURL": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["placed", "confirmed", "dispatched", "delivered"] },
        "deliveryAddress": { "type": "object" },
        "deliveryOption": { "type": "string", "enum": ["home", "pickup"] },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "User wishlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "SmartList": {
      "title": "SmartList",
      "description": "Reusable shopping list",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "productIds": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/carts/{userId}": { "schema": "Cart", "description": "User shopping carts" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/wishlists/{userId}": { "schema": "Wishlist", "description": "User wishlists" },
    "/smartLists/{listId}": { "schema": "SmartList", "description": "Reusable shopping lists" }
  }
}
