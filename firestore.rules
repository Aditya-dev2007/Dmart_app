rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, phoneNumber, role, addresses, createdAt
    //
    // Collection: products
    // Fields: id, name, description, price, discount, brand, category, stock, imageURL, ecoScore, relatedProductIds
    //
    // Collection: categories
    // Fields: id, name, imageURL
    //
    // Collection: carts
    // Fields: userId, items, updatedAt
    //
    // Collection: orders
    // Fields: id, userId, items, total, status, deliveryAddress, deliveryOption, paymentMethod, createdAt
    //
    // Collection: wishlists
    // Fields: userId, productIds
    //
    // Collection: smartLists
    // Fields: id, userId, name, productIds
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "gangjiaditya25@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['customer', 'admin'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.stock is int && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.total is number && data.total >= 0 &&
             data.status in ['placed', 'confirmed', 'dispatched', 'delivered'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.resource.data.role == 'customer' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /wishlists/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /smartLists/{listId} {
      allow read, write: if isOwner(resource.data.userId) || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
